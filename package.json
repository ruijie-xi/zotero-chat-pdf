{
  "name": "zotero-plugin-chatpdf",
  "type": "module",
  "version": "0.8.4",
  "description": "Chat with your PDFs using LLMs in Zotero",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruijie-xi/zotero-chat-pdf.git"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "defu": "6.1.7",
    "esbuild": "0.28.1",
    "markdown-it": "14.3.0"
  },
  "config": {
    "addonName": "ChatPDF",
    "addonID": "chatpdf@zotero-plugin",
    "addonRef": "chatpdf",
    "addonInstance": "ChatPDF",
    "prefsPrefix": "extensions.zotero.chatpdf",
    "xpiName": "chat-pdf",
    "xpiDownloadLink": "https://github.com/ruijie-xi/zotero-chat-pdf/releases/download/v{{version}}/{{xpiName}}.xpi",
    "updateURL": "https://github.com/ruijie-xi/zotero-chat-pdf/releases/download/release/update.json"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint src tests scripts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "verify:release": "node scripts/validate-release.mjs",
    "release": "zotero-plugin release"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-document": "^3.20.1",
    "@tiptap/extension-history": "^3.20.1",
    "@tiptap/extension-mention": "^3.20.1",
    "@tiptap/extension-paragraph": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "katex": "^0.16.33",
    "marked": "^17.0.3",
    "pdf-lib": "^1.17.1",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  }
}
